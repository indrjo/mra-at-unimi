
;; esercizio 1

;; the cards on the table
(declare-datatypes () ((Card A B C D E F G H I J)))

;; Possible moves
(declare-datatypes () ((Move START ; for the initial position only
                             UP    ; go up
                             DOWN  ; go down
                             STOP  ; for the final position only
                             )))

;; A predicate to tell whether a card falls over some other card.
(define-fun is-over ((c1 Card) (c2 Card)) Bool
            (or
             ;; A
             (and (= c1 A)
                  (= c2 B))
             ;; B
             (and (= c1 B)
                  (= c2 F))
             (and (= c1 B)
                  (= c2 G))
             ;; C
             (and (= c1 C)
                  (= c2 B))
             (and (= c1 C)
                  (= c2 D))
             ;; D
             ;; nothing
             ;; E
             (and (= c1 E)
                  (= c2 C))
             (and (= c1 E)
                  (= c2 D))
             ;; F
             (and (= c1 F)
                  (= c2 C))
             (and (= c1 F)
                  (= c2 E))
             ;; G
             (and (= c1 G)
                  (= c2 F))
             (and (= c1 G)
                  (= c2 H))
             ;; H
             (and (= c1 H)
                  (= c2 F))
             ;; I
             (and (= c1 I)
                  (= c2 E))
             (and (= c1 I)
                  (= c2 J))
             ;; J
             (and (= c1 J)
                  (= c2 H))))

(define-fun is-initial-state ((pos Card) (how Move)) Bool
            (and (= pos A) (= how START)))

(define-fun is-final-state ((pos Card) (how Move)) Bool
            (and (= pos J)
                 (or (= how STOP)
                     (= how UP)
                     (= how DOWN))))

(define-fun is-stop-state ((pos Card) (how Move)) Bool
            (and (= pos J) (= how STOP)))

(define-fun transition ((pos1 Card) (how1 Move)
                        (pos2 Card) (how2 Move)) Bool
                        (or
                         ;; If you are on J, keep remaining on it and
                         ;; STOP. Otherwise, you should move. This is
                         ;; made to allow the finding of solutions
                         ;; without redundancy: if you reach J, stay
                         ;; there, because without that condition you
                         ;; could move as well from that card.
                         (and (is-final-state pos1 how1)
                              (is-stop-state pos2 how2))
                         (and (is-over pos1 pos2)
                              (not (is-final-state pos1 how1))
                              (or (= how1 UP) (= how1 START))
                              (= how2 DOWN))
                         (and (is-over pos2 pos1)
                              (not (is-final-state pos1 how1))
                              (= how1 DOWN)
                              (= how2 UP))))

;; The following part is generated by a shell script.
;;
;; $ ./make-esercizio1.sh 10 >> esercizio1.smt2
;;
;; If you want to try a different number of steps, delete all the lines
;; below and run the line above with a different number in place of 10.
;;
;; !!! The minimum number of steps to obtain SAT is 10.

(declare-const pos1 Card)
(declare-const how1 Move)
(declare-const pos2 Card)
(declare-const how2 Move)
(declare-const pos3 Card)
(declare-const how3 Move)
(declare-const pos4 Card)
(declare-const how4 Move)
(declare-const pos5 Card)
(declare-const how5 Move)
(declare-const pos6 Card)
(declare-const how6 Move)
(declare-const pos7 Card)
(declare-const how7 Move)
(declare-const pos8 Card)
(declare-const how8 Move)
(declare-const pos9 Card)
(declare-const how9 Move)
(declare-const pos10 Card)
(declare-const how10 Move)

(assert (is-initial-state pos1 how1))
(assert (transition pos1 how1 pos2 how2))
(assert (transition pos2 how2 pos3 how3))
(assert (transition pos3 how3 pos4 how4))
(assert (transition pos4 how4 pos5 how5))
(assert (transition pos5 how5 pos6 how6))
(assert (transition pos6 how6 pos7 how7))
(assert (transition pos7 how7 pos8 how8))
(assert (transition pos8 how8 pos9 how9))
(assert (transition pos9 how9 pos10 how10))
(assert (is-final-state pos10 how10))

(check-sat)

(get-value (how1))
(get-value (pos1))
(get-value (how2))
(get-value (pos2))
(get-value (how3))
(get-value (pos3))
